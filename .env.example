# Nori Stack — Environment Variables
# Copy to rootsystem/application/.env and adjust values

DEBUG=true
SECRET_KEY=change-me-in-production

# Database engine: mysql | postgres | sqlite
DB_ENGINE=mysql

# MySQL defaults
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=nori_app

# For PostgreSQL, change:
# DB_ENGINE=postgres
# DB_PORT=5432

# For SQLite (testing/prototyping), change:
# DB_ENGINE=sqlite
# DB_NAME=db.sqlite3

# For docker-compose, use:
# DB_HOST=db

# CORS — allowed origins separated by comma (empty = disabled)
# CORS_ORIGINS=http://localhost:3000,https://myapp.com
CORS_ORIGINS=

# File Uploads — driver: local (default) | (register custom drivers in your app)
# STORAGE_DRIVER=local
# UPLOAD_MAX_SIZE=10485760

# Google Cloud Storage (register services/storage_gcs.py, then STORAGE_DRIVER=gcs)
# GCS_BUCKET=my-bucket
# GCS_CREDENTIALS_FILE=/path/to/service-account.json
# GCS_CREDENTIALS_JSON=             # alternative: paste the JSON as a string
# GCS_URL_PREFIX=https://cdn.example.com    # optional: custom public URL prefix

# Email — driver: smtp (default) | log | (register custom drivers in your app)
# MAIL_DRIVER=smtp
# MAIL_HOST=smtp.example.com
# MAIL_PORT=587
# MAIL_USER=
# MAIL_PASSWORD=
# MAIL_FROM=noreply@example.com
# MAIL_TLS=true

# JWT / API Tokens
# JWT_SECRET=change-me-in-production
# JWT_EXPIRATION=3600

# Queue — memory (default), database, or redis
# QUEUE_DRIVER=memory

# Rate Limiting — memory (default) or redis
# THROTTLE_BACKEND=memory

# Caching — memory (default) or redis
# CACHE_BACKEND=memory
# CACHE_MAX_KEYS=10000

# Redis — shared by queue, throttle, and cache when using redis backends
# REDIS_URL=redis://localhost:6379

# Trusted proxies — set to your reverse proxy IP for correct client IP detection
# TRUSTED_PROXIES=127.0.0.1

# Search — register a driver in your app (e.g. services/search_meilisearch.py)
# SEARCH_DRIVER=meilisearch
# MEILISEARCH_URL=http://localhost:7700
# MEILISEARCH_API_KEY=

# Logging
# LOG_LEVEL=INFO          # DEBUG | INFO | WARNING | ERROR | CRITICAL
# LOG_FORMAT=text          # text | json
# LOG_FILE=nori.log        # optional: enable file logging with rotation

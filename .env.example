# Nori Stack — Variables de entorno
# Copiar a rootsystem/application/.env y ajustar valores

DEBUG=true
SECRET_KEY=change-me-in-production

# Database engine: mysql | postgres
DB_ENGINE=mysql

# MySQL defaults
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=nori_app

# CORS — origenes permitidos separados por coma (vacio = desactivado)
# CORS_ORIGINS=http://localhost:3000,https://miapp.com
CORS_ORIGINS=

# Para PostgreSQL, cambiar:
# DB_ENGINE=postgres
# DB_PORT=5432

# Para SQLite (testing/prototyping), cambiar:
# DB_ENGINE=sqlite
# DB_NAME=db.sqlite3

# Para docker-compose, usar:
# DB_HOST=db

# File Uploads
# UPLOAD_MAX_SIZE=10485760

# Email (SMTP)
# MAIL_HOST=smtp.example.com
# MAIL_PORT=587
# MAIL_USER=
# MAIL_PASSWORD=
# MAIL_FROM=noreply@example.com
# MAIL_TLS=true

# JWT / API Tokens
# JWT_SECRET=change-me-in-production
# JWT_EXPIRATION=3600

# Rate Limiting — memory (default) o redis
# THROTTLE_BACKEND=memory
# REDIS_URL=redis://localhost:6379
